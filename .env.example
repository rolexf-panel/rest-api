# Konfigurasi Aplikasi
PORT=3000
APP_ENV=development
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/rest_api

# Autentikasi
JWT_SECRET=rahasia-super-aman-di-sini
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=rahasia-refresh-token
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_FREE=100
RATE_LIMIT_PAID=1000
RATE_LIMIT_WINDOW=15

# API Eksternal
OPENWEATHERMAP_API_KEY=
CURRENCY_API_KEY=
TELEGRAM_BOT_TOKEN=

# Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# CORS
CORS_ORIGIN=*
